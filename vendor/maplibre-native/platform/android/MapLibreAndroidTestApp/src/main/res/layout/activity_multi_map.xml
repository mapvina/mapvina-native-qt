<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:mapvina="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:ignore="NestedWeights">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="0.5"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <!-- DC -->
        <fragment
            android:id="@+id/map1"
            class="com.mapvina.android.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="0.5"
            mapvina:mapvina_cameraTargetLat="38.913187"
            mapvina:mapvina_cameraTargetLng="-77.032546"
            mapvina:mapvina_cameraZoom="12" />

        <!-- SF -->
        <fragment
            android:id="@+id/map2"
            class="com.mapvina.android.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="0.5"
            mapvina:mapvina_cameraTargetLat="37.775732"
            mapvina:mapvina_cameraTargetLng="-122.413985"
            mapvina:mapvina_cameraZoom="13"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="0.5"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <!-- Bangalore -->
        <fragment
            android:id="@+id/map3"
            class="com.mapvina.android.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="0.5"
            mapvina:mapvina_cameraTargetLat="12.97913"
            mapvina:mapvina_cameraTargetLng="77.59188"
            mapvina:mapvina_cameraZoom="14" />

        <!-- Ayacucho -->
        <fragment
            android:id="@+id/map4"
            class="com.mapvina.android.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="0.5"
            mapvina:mapvina_cameraTargetLat="-13.155980"
            mapvina:mapvina_cameraTargetLng="-74.217134"
            mapvina:mapvina_cameraZoom="15" />
    </LinearLayout>
</LinearLayout>
